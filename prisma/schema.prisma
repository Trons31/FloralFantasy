generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  pin       String?
  notifications Notification[]
  notificationOutboxes NotificationOutbox[]
  notificationState UserNotificationState?
  pushTokens  PushToken[]
  fcmTokens   FCMToken[]
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  SUPER_ADMIN
  PREPARADOR
  REPARTIDOR
  CORREDOR
}

enum OrderSource {
  CLIENT
  ADMIN
}


model Flower {
  id          String          @id @default(cuid())
  name        String
  type        String
  description String?
  imageUrl    String?
  createdAt   DateTime        @default(now())
  products    ProductFlower[]
}

model Occasion {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  subtitle         String?
  advanceOrderDays Int              @default(0)
  sortOrder        Int              @default(0)
  isActive         Boolean          @default(true)
  images           OccasionImage[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model OccasionImage {
  id         String   @id @default(cuid())
  occasionId String
  occasion   Occasion  @relation(fields: [occasionId], references: [id], onDelete: Cascade)
  url        String
  publicId   String?
  isMain     Boolean  @default(false)
  order      Int      @default(0)
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id                   String          @id @default(cuid())
  name                 String
  description          String
  price                Float
  categoryId           String
  category             Category        @relation(fields: [categoryId], references: [id])
  occasion             String?
  images               ProductImage[]
  flowers              ProductFlower[]
  preparationTimeValue Int             @default(0)
  preparationTimeUnit  TimeUnit        @default(MINUTES)
  deliveryLeadDays     Int             @default(0)
  requiresSpecialOrder Boolean         @default(false)
  inStock              Boolean         @default(true)
  featured             Boolean         @default(false)
  createdAt            DateTime        @default(now())
  orderItems           OrderItem[]
}

enum TimeUnit {
  MINUTES
  HOURS
  DAYS
}

model ProductFlower {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  flowerId  String
  flower    Flower  @relation(fields: [flowerId], references: [id])
  quantity  Int     @default(1)
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  isMain    Boolean @default(false)
  order     Int     @default(0)
}

model AddOn {
  id         String           @id @default(cuid())
  name       String
  price      Float
  type       AddOnType
  imageUrl   String?
  inStock    Boolean          @default(true)
  orderItems OrderItemAddOn[]
}

enum AddOnType {
  BEBIDA
  VINO
  PELUCHE
  DULCE
  CANASTA
  OTRO
}

model Order {
  id              String               @id @default(cuid())
  trackingToken   String               @unique
  status          OrderStatus          @default(PENDING)
  customerName    String
  customerPhone   String
  customerEmail   String
  address         String
  addressRef      String?
  total           Float
  deliveryFee     Float                @default(0)
  source          OrderSource          @default(CLIENT)
  estimatedTime   String               @default("1 dia")
  paymentMethodId String?
  paymentMethod   PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  paymentProofUrl String?
  paymentProofPublicId String?
  deliveryPhotoUrl String?
  deliveryPhotoPublicId String?
  adminNote       String?
  manualAdjustment Float               @default(0)
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  notifications   Notification[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

enum OrderStatus {
  PENDING
  PENDING_PAYMENT_CONFIRMATION
  PAYMENT_INVALID
  PAID
  PROCESSING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum NotificationStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  RETRYING
  FAILED
}

enum NotificationQueueStatus {
  QUEUED
  PROCESSING
  SENT
  RETRYING
  FAILED
}

enum NotificationChannel {
  INBOX_SYNC
  WEB_PUSH
  FCM
  EXPO
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

enum PaymentMethodType {
  QR
  BANK_ACCOUNT
  INSTRUCTIONS
}

model PaymentMethod {
  id                String   @id @default(cuid())
  title             String
  provider          String?
  visibleLabel      String?
  type              PaymentMethodType
  details           String?
  accountNumber     String?
  imageUrl          String?
  imagePublicId     String?
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  orders            Order[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OrderItem {
  id        String           @id @default(cuid())
  orderId   String
  order     Order            @relation(fields: [orderId], references: [id])
  productId String
  product   Product          @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  customization Json?
  addons    OrderItemAddOn[]
}

model OrderItemAddOn {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  addonId     String
  addon       AddOn     @relation(fields: [addonId], references: [id])
  price       Float
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

model Expense {
  id              String   @id @default(cuid())
  description     String
  amount          Float
  category        String
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  receiptPhotoUrl     String?
  receiptPublicId     String?
  registeredBy    String?
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  auth      String
  endpoint  String   @unique
  p256dh    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FCMToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserNotificationState {
  userId                String   @id
  lastSequence          Int      @default(0)
  lastDeliveredSequence Int      @default(0)
  lastReadSequence      Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String                  @id @default(cuid())
  userId      String
  orderId     String?
  sequence    Int
  type        String
  title       String
  body        String
  payload     Json?
  dedupeKey   String?
  status      NotificationStatus      @default(PENDING)
  queuedAt    DateTime?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  lastError   String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  deliveries  NotificationDelivery[]
  outbox      NotificationOutbox?
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([userId, sequence])
  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
  @@index([userId, status, sequence])
}

model NotificationOutbox {
  id                  String                  @id @default(cuid())
  notificationId      String                  @unique
  userId              String
  status              NotificationQueueStatus @default(QUEUED)
  attemptCount        Int                     @default(0)
  nextAttemptAt       DateTime                @default(now())
  processingStartedAt DateTime?
  lastAttemptAt       DateTime?
  sentAt              DateTime?
  lastError           String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  notification        Notification            @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([userId, status, nextAttemptAt])
}

model NotificationDelivery {
  id                String                     @id @default(cuid())
  notificationId    String
  channel           NotificationChannel
  status            NotificationDeliveryStatus @default(PENDING)
  attempt           Int                        @default(1)
  providerMessageId String?
  lastError         String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  notification      Notification               @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, channel])
  @@index([channel, status])
  @@index([notificationId, status])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
