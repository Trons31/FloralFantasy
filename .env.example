# Database (Supabase recommended)
# Use the transaction pooler for the app and add `?pgbouncer=true`.
DATABASE_URL=""
# Use the direct database URL for Prisma migrations / CLI.
DIRECT_URL=""

# Base URL
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Comma-separated list of emails allowed to sign in as super admins
# Example: SUPER_ADMIN_EMAILS="tu@correo.com,cliente@correo.com"
SUPER_ADMIN_EMAILS=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

WOMPI_PUBLIC_KEY="pub_test_xxxx"
WOMPI_PRIVATE_KEY="prv_test_xxxx"
WOMPI_EVENTS_SECRET="your-events-secret"
NEXT_PUBLIC_WOMPI_PUBLIC_KEY="pub_test_xxxx"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu@gmail.com"
SMTP_PASS="app-password"
SMTP_FROM="Fantasía Floral <tu@gmail.com>"

# Web-Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:tu@gmail.com"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

DELIVERY_FEE=8000
